# Fleetum Frontend Environment Example
# Vite exposes only variables prefixed with VITE_. Do not put secrets here.

# Tenant app API. Use /api in production behind Caddy, or http://127.0.0.1:4000/api locally.
VITE_API_BASE_URL=/api

# Platform Console API. Use /platform-api in production behind Caddy.
VITE_PLATFORM_API_BASE_URL=http://127.0.0.1:4100/platform-api

# URL used by Platform Console links that jump back to the tenant app.
VITE_CLIENT_APP_URL=http://127.0.0.1:5173/dashboard

# OAuth entrypoints exposed by the backend.
VITE_GOOGLE_AUTH_URL=/api/auth/google
VITE_APPLE_AUTH_URL=/api/auth/apple
