# Fleetum staging backend env example.
# Copy outside the repository, for example /opt/fleetum-staging/env/backend.env.

NODE_ENV=production
PORT=4000
PLATFORM_PORT=4100
PLATFORM_BIND_HOST=0.0.0.0
TRUST_PROXY=1

DATABASE_URL=postgresql://fleetum_staging:CHANGE_ME@postgres:5432/fleetum_staging?schema=public

APP_URL=https://staging.fleetum.it
BACKEND_PUBLIC_URL=https://api-staging.fleetum.it
CORS_ORIGIN=https://staging.fleetum.it
PLATFORM_CORS_ORIGIN=https://platform-staging.fleetum.it

JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_EXPIRES_IN=15m
PLATFORM_JWT_SECRET=CHANGE_ME_MIN_64_CHARS
PLATFORM_JWT_EXPIRES_IN=15m
PLATFORM_ADMIN_EMAIL=info@fleetum.it
# Genera con:
# node -e "require('bcryptjs').hash('TUA_PASSWORD',12).then(console.log)"
PLATFORM_ADMIN_PASSWORD_HASH=$2b$12$CHANGE_ME_BCRYPT_HASH
PLATFORM_ALLOWED_IPS=127.0.0.1
PLATFORM_ALERT_EMAILS=info@fleetum.it

UPLOAD_DIR=uploads
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_EXPIRES_SECONDS=300

PRISMA_SLOW_QUERY_MS=
METRICS_ENABLED=true
METRICS_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

EMAIL_PROVIDER=resend
RESEND_FROM=Fleetum Staging <no-reply@fleetum.it>
RESEND_API_KEY=CHANGE_ME
DEMO_LEAD_RECIPIENT_EMAIL=info@fleetum.it

STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER_MONTHLY=price_test_starter_monthly
STRIPE_PRICE_STARTER_YEARLY=price_test_starter_yearly
STRIPE_PRICE_PRO_MONTHLY=price_test_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_test_pro_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_test_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_test_enterprise_yearly
