# Fleetum production backup env example.
# Copy outside the repository, for example /opt/fleetum/env/backup.env.
# Never commit real credentials.

# Offsite backup is mandatory in production.
BACKUP_OFFSITE_REQUIRED=true
RETENTION_DAYS=30

# Local paths.
BACKUP_DIR=/opt/fleetum/backups/postgres
UPLOADS_DIR=/opt/fleetum/uploads
COMPOSE_FILE=/opt/fleetum/app/docker-compose.prod.yml
ENV_FILE=/opt/fleetum/env/compose.env
POSTGRES_SERVICE_NAME=postgres
POSTGRES_USER=fleetum
POSTGRES_DB=fleetum
# Managed PostgreSQL direct URL for pg_dump. Required after removing the local postgres service.
# Use a direct/session connection with sslmode=require, not a transaction pooler.
PG_DUMP_DATABASE_URL=

# Option A: rclone target. Recommended for Cloudflare R2, Backblaze B2 or S3.
# Configure rclone outside git: rclone config
OFFSITE_RCLONE_TARGET=fleetum-r2:fleetum-backups
RCLONE_TRANSFERS=4

# Option B: aws-cli compatible target. Leave empty if using rclone.
# For AWS S3: OFFSITE_S3_URI=s3://fleetum-backups/prod
# For Cloudflare R2/B2: set S3_ENDPOINT_URL as provider endpoint.
OFFSITE_S3_URI=
S3_ENDPOINT_URL=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# Alerts. Resend recommended because Fleetum already uses it.
BACKUP_ALERT_EMAIL=ops@example.com
BACKUP_ALERT_SUBJECT=Fleetum backup failure
BACKUP_NOTIFY_SUCCESS=false
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_FROM=Fleetum Backups <no-reply@fleetum.it>

# Disk capacity alerts reuse this Resend channel. Leave DISK_ALERT_EMAIL empty to
# reuse BACKUP_ALERT_EMAIL. Thresholds are GitHub production Variables so deploys
# can be tuned without storing infrastructure secrets in the repository.
DISK_ALERT_EMAIL=
# Optional Slack/Discord/Better Stack webhook.
BACKUP_ALERT_WEBHOOK_URL=

# Restore test isolated container.
POSTGRES_IMAGE=postgres:16-alpine
TEST_CONTAINER=fleetum_restore_test_postgres
TEST_DB=fleetum_restore_test
TEST_USER=fleetum_restore_test
TEST_PASSWORD=CHANGE_ME_RESTORE_TEST_PASSWORD
