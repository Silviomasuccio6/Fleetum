NODE_ENV=production
PORT=4000
PLATFORM_PORT=4100
PLATFORM_BIND_HOST=0.0.0.0
TRUST_PROXY=1
SHUTDOWN_GRACE_MS=15000

# Runtime connection. For managed PostgreSQL prefer provider pooler/session URL with SSL.
# Neon example: postgresql://fleetum_owner:CHANGE_ME@ep-example-pooler.eu-central-1.aws.neon.tech/fleetum?sslmode=require&connection_limit=5
DATABASE_URL=postgresql://fleetum_owner:CHANGE_ME_DB_PASSWORD@ep-example-pooler.eu-central-1.aws.neon.tech/fleetum?sslmode=require&connection_limit=5
# Direct connection for Prisma migrations, pg_dump and admin tooling. Do not route migrations through transaction poolers.
DIRECT_URL=postgresql://fleetum_owner:CHANGE_ME_DB_PASSWORD@ep-example.eu-central-1.aws.neon.tech/fleetum?sslmode=require
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
# Il refresh token rinnova automaticamente l'access token.
JWT_EXPIRES_IN=15m
PLATFORM_JWT_SECRET=CHANGE_ME_DIFFERENT_MIN_64_CHARS
PLATFORM_JWT_EXPIRES_IN=15m

APP_URL=https://fleetum.it
BACKEND_PUBLIC_URL=https://api.fleetum.it
CORS_ORIGIN=https://fleetum.it
PLATFORM_CORS_ORIGIN=https://platform.fleetum.it
OAUTH_CALLBACK_URL=https://fleetum.it/auth/social-callback

# Google OAuth login/signup.
# Valori reali solo in GitHub Actions/VPS secrets, mai nel repository.
# Redirect autorizzato in Google Cloud Console prod:
# https://api.fleetum.it/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.fleetum.it/api/auth/google/callback
GOOGLE_WORKSPACE_REDIRECT_URI=https://api.fleetum.it/api/calendar/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://api.fleetum.it/api/auth/apple/callback

UPLOAD_DIR=uploads
FILE_MAX_IMAGE_MB=5
FILE_MAX_DOCUMENT_MB=12
FILE_MAX_LOGO_MB=4
IMAGE_MAX_WIDTH_PX=1920
IMAGE_COMPRESSION_QUALITY=82
IMAGE_PNG_COMPRESSION_LEVEL=9
STORAGE_PROVIDER=local
# S3-compatible private object storage. Keep objects private by default; expose only via auth or signed URLs.
# AWS S3 example endpoint: https://s3.eu-south-1.amazonaws.com
# Cloudflare R2 example endpoint: https://<account-id>.r2.cloudflarestorage.com with S3_REGION=auto
# Backblaze B2 example endpoint: https://s3.<region>.backblazeb2.com
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_EXPIRES_SECONDS=300

# Observability
# Default production slow query threshold is 500ms; >=2000ms is logged as error.
PRISMA_SLOW_QUERY_MS=
METRICS_ENABLED=true
METRICS_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
PRIVACY_RETENTION_CRON_ENABLED=true
PRIVACY_RETENTION_CRON_SCHEDULE=30 3 * * *

EMAIL_PROVIDER=resend
# Required: use a Resend API key stored only on the VPS/GitHub Secrets, never in the repository.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM="Fleetum <no-reply@fleetum.it>"
DEMO_LEAD_RECIPIENT_EMAIL=info@fleetum.it

CRON_REMINDER_SCHEDULE=*/10 * * * *
SLA_PRIORITY_THRESHOLDS={"LOW":15,"MEDIUM":10,"HIGH":5,"CRITICAL":2}

PLATFORM_ADMIN_EMAIL=admin@fleetum.it
# Genera con:
# node -e "require('bcryptjs').hash('TUA_PASSWORD',12).then(console.log)"
# Keep bcrypt hashes unquoted: Fleetum compose files read this env file in raw mode.
PLATFORM_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_A_REAL_60_CHARACTER_BCRYPT_HASH
PLATFORM_ADMIN_OTP=
# strict = solo IP allowlist; optional = IP allowlist oppure dispositivo fidato dopo OTP; disabled = solo password+OTP+JWT.
PLATFORM_IP_ALLOWLIST_MODE=optional
PLATFORM_TRUSTED_DEVICE_ENABLED=true
PLATFORM_TRUSTED_DEVICE_TTL_DAYS=90
PLATFORM_ALLOWED_IPS=
PLATFORM_ALERT_EMAILS=
PLATFORM_LOGIN_MAX_ATTEMPTS=5
PLATFORM_LOGIN_WINDOW_MS=900000
PLATFORM_LOGIN_LOCK_MS=1800000

BILLING_TRIAL_DAYS=14
# Giorni usati per comunicazioni e dunning PAST_DUE. Non sblocca il license guard.
BILLING_PAST_DUE_GRACE_DAYS=7
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
