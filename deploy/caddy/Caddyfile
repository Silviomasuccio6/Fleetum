{
	email {$CADDY_EMAIL}
}

(security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=15552000"
		-Server
		defer
	}
}

(frontend_cache_headers) {
	@html path / /index.html /platform.html
	header @html Cache-Control "no-cache"
}

(secure_error_responses) {
	handle_errors {
		import security_headers
		respond "{err.status_code} {err.status_text}" {err.status_code}
	}
}

fleetum.it, www.fleetum.it {
	import security_headers
	import frontend_cache_headers
	import secure_error_responses
	encode zstd gzip

	route /api/* {
		reverse_proxy backend:4000
	}

	route /assets/* {
		root * /srv/fleetum
		file_server
	}

	route /brand/* {
		root * /srv/fleetum
		file_server
	}

	route {
		root * /srv/fleetum
		@landing_root path /
		rewrite @landing_root /index.html
		@prerendered_public path /software-autonoleggio /software-rent-a-car /gestionale-flotta /booking-noleggi /contratti-noleggio-digitali /report-redditivita-veicolo /prezzi /demo /privacy /cookie /termini /dpa
		rewrite @prerendered_public {path}/index.html
		try_files {path} /spa.html
		file_server
	}
}

api.fleetum.it {
	import security_headers
	encode zstd gzip

	route /api/* {
		reverse_proxy backend:4000
	}

	respond "Fleetum API" 200
}

platform.fleetum.it {
	import security_headers
	import frontend_cache_headers
	import secure_error_responses
	encode zstd gzip

	route /platform-api/* {
		reverse_proxy backend:4100
	}

	route /assets/* {
		root * /srv/fleetum
		file_server
	}

	route /brand/* {
		root * /srv/fleetum
		file_server
	}

	route {
		root * /srv/fleetum
		try_files {path} /platform.html
		file_server
	}
}
