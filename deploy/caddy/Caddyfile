{
	email {$CADDY_EMAIL}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
		defer
	}
}

(spa_cache_headers) {
	@html path / /index.html /platform.html
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	@static path /assets/* /brand/* /favicon.ico /apple-touch-icon.png
	header @static Cache-Control "public, max-age=31536000, immutable"
}

(secure_error_responses) {
	handle_errors {
		import security_headers
		respond "{err.status_code} {err.status_text}" {err.status_code}
	}
}

fleetum.it, www.fleetum.it {
	import security_headers
	import spa_cache_headers
	import secure_error_responses
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:4000
	}

	handle /assets/* {
		root * /srv/fleetum
		file_server
	}

	handle /brand/* {
		root * /srv/fleetum
		file_server
	}

	handle {
		root * /srv/fleetum
		try_files {path} /index.html
		file_server
	}
}

api.fleetum.it {
	import security_headers
	import secure_error_responses
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:4000
	}

	respond "Fleetum API" 200
}

platform.fleetum.it {
	import security_headers
	import spa_cache_headers
	import secure_error_responses
	encode zstd gzip

	handle /platform-api/* {
		reverse_proxy backend:4100
	}

	handle /assets/* {
		root * /srv/fleetum
		file_server
	}

	handle /brand/* {
		root * /srv/fleetum
		file_server
	}

	handle {
		root * /srv/fleetum
		try_files {path} /platform.html
		file_server
	}
}
