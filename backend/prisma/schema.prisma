generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum RoleKey {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum StoppageStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  SOLICITED
  CLOSED
  CANCELED
}

enum StoppagePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmailQueueStatus {
  PENDING
  SENT
  FAILED
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  SENT
  PAID
  OVERDUE
  VOID
  ERROR
}

enum InvoiceDeliveryChannel {
  EMAIL
}

enum InvoiceDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum WebsiteEventType {
  PAGE_VIEW
  CTA_CLICK
  DEMO_FORM_VIEW
  DEMO_FORM_SUBMIT
  SIGNUP_VIEW
  SIGNUP_STARTED
  SIGNUP_COMPLETED
  ONBOARDING_COMPANY_COMPLETED
  STRIPE_CHECKOUT_STARTED
  STRIPE_CHECKOUT_COMPLETED
  STRIPE_CHECKOUT_FAILED
  TRIAL_ACTIVATED
  LOGIN_CLICK
  PRICING_VIEW
}

enum DemoLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
  SPAM
}

enum RentalBookingStatus {
  DRAFT
  QUOTED
  HOLD
  CONFIRMED
  CONTRACT_SIGNED
  READY_FOR_HANDOVER
  IN_RENT
  CLOSED
  CANCELED
  NO_SHOW
}

enum RentalContractStatus {
  NOT_READY
  READY
  SIGNED
}

enum RentalCargosStatus {
  NOT_REQUIRED
  PENDING
  SENT
  ERROR
}

enum VehicleCostType {
  PURCHASE
  INSURANCE
  TAX
  MAINTENANCE
  REPAIR
  REVISION
  CLEANING
  OTHER
}

enum BookingContractStatus {
  DRAFT
  READY
  SENT
  SIGNED
  ERROR
}

enum BookingContractDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum BookingContractDeliveryChannel {
  EMAIL
  WHATSAPP
}

enum RentalPricingScope {
  GLOBAL
  SITE
  VEHICLE_CATEGORY
  VEHICLE
}

enum RentalBaseRateUnit {
  DAILY
  WEEKLY
  MONTHLY
}

enum RentalKmPackageType {
  LIMITED
  UNLIMITED
}

enum RentalKmScope {
  PER_DAY
  PER_RENTAL
}

enum RentalExtraKmPolicyType {
  FLAT
  TIERED
}

enum RentalHourOverflowRule {
  NONE
  HALF_DAY
  FULL_DAY
}

enum RentalCustomerType {
  PERSONA_FISICA
  PERSONA_GIURIDICA
}

enum RentalPaymentMethodStatus {
  SETUP_PENDING
  ACTIVE
  FAILED
  REQUIRES_ACTION
  EXPIRED
  REMOVED
}

enum RentalDepositStatus {
  DRAFT
  AUTHORIZING
  AUTHORIZED
  PARTIALLY_CAPTURED
  CAPTURED
  RELEASED
  CANCELED
  FAILED
  EXPIRED
}

enum RentalExtraChargeStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  NOTIFIED
  PAYMENT_PROCESSING
  PAID
  FAILED
  REQUIRES_ACTION
  CANCELED
  REFUNDED
  DISPUTED
}

enum RentalExtraChargeType {
  FINE
  DAMAGE
  DEDUCTIBLE
  FUEL
  TOLL
  LATE_RETURN
  CLEANING
  MISSING_ACCESSORY
  ADMIN_FEE
  OTHER
}

model Tenant {
  id                            String                         @id @default(cuid())
  /// @pii
  name                          String
  /// @pii
  vatNumber                     String?
  isActive                      Boolean                        @default(true)
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  deletedAt                     DateTime?
  users                         User[]
  sites                         Site[]
  workshops                     Workshop[]
  vehicles                      Vehicle[]
  vehicleCosts                  VehicleCost[]
  stoppages                     Stoppage[]
  reminders                     Reminder[]
  auditLogs                     AuditLog[]
  calendarEvents                CalendarEvent[]
  vehicleMaintenances           VehicleMaintenance[]
  vehicleMaintenanceAttachments VehicleMaintenanceAttachment[]
  vehicleBooklets               VehicleBooklet[]
  rentalBookings                RentalBooking[]
  rentalBookingNotes            RentalBookingNote[]
  rentalCustomers               RentalCustomer[]
  rentalCustomerAttachments     RentalCustomerAttachment[]
  rentalCustomerPaymentProfiles RentalCustomerPaymentProfile[]
  rentalCustomerPaymentMethods  RentalCustomerPaymentMethod[]
  rentalDeposits                RentalDeposit[]
  rentalExtraCharges            RentalExtraCharge[]
  rentalPaymentEvents           RentalPaymentEvent[]
  contractTemplates             ContractTemplate[]
  bookingContracts              BookingContract[]
  bookingContractEvents         BookingContractEvent[]
  bookingContractDeliveries     BookingContractDelivery[]
  rentalPriceLists              RentalPriceList[]
  rentalPricePackages           RentalPricePackage[]
  rentalExtraKmPolicies         RentalExtraKmPolicy[]
  rentalExtraKmTiers            RentalExtraKmTier[]
  rentalBookingPricingSnapshots RentalBookingPricingSnapshot[]
  privacyAcceptances            PrivacyAcceptance[]
  storedFileObjects             StoredFileObject[]
  tenantProfile                 TenantProfile?
  tenantBranding                TenantBranding?
  tenantLegalSettings           TenantLegalSettings?
  tenantSubscription            TenantSubscription?
  billingEvents                 BillingEvent[]
  invoices                      Invoice[]
  consentLogs                   ConsentLog[]

  @@index([isActive])
}

model TenantSubscription {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  provider             String    @default("local")
  plan                 String    @default("STARTER")
  billingCycle         String    @default("monthly")
  status               String    @default("ACTIVE")
  seats                Int       @default(3)
  priceMonthly         Float?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([plan, status])
  @@index([status, currentPeriodEnd])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model BillingEvent {
  id           String    @id @default(cuid())
  eventId      String    @unique
  provider     String    @default("stripe")
  type         String
  tenantId     String?
  processedAt  DateTime?
  status       String    @default("RECEIVED")
  errorMessage String?
  payload      Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([provider, type])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

model TenantProfile {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  /// @pii
  legalName          String
  /// @pii
  tradeName          String?
  /// @pii
  legalForm          String?
  /// @pii
  vatNumber          String?
  /// @pii
  taxCode            String?
  /// @pii
  pec                String?
  /// @pii
  sdiCode            String?
  /// @pii
  rea                String?
  /// @pii
  legalAddress       String?
  /// @pii
  city               String?
  /// @pii
  province           String?
  /// @pii
  postalCode         String?
  country            String    @default("IT")
  /// @pii
  phone              String?
  /// @pii
  email              String?
  /// @pii
  website            String?
  /// @pii
  adminFirstName     String?
  /// @pii
  adminLastName      String?
  /// @pii
  adminEmail         String?
  /// @pii
  adminPhone         String?
  /// @pii
  adminRole          String?
  profileCompletedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  tenant             Tenant    @relation(fields: [tenantId], references: [id])

  @@index([vatNumber])
  @@index([taxCode])
  @@index([email])
  @@index([tenantId, deletedAt])
}

model TenantBranding {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  /// @pii
  logoFilePath  String?
  /// @pii
  logoFileName  String?
  logoMimeType  String?
  primaryColor  String?
  accentColor   String?
  fontFamily    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

model TenantLegalSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  /// @pii
  contractFooterText   String?
  /// @pii
  defaultContractTerms String?
  privacyNoticeVersion String?
  termsVersion         String?
  dpaVersion           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
}

model CalendarEvent {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  /// @pii
  title        String
  /// @pii
  description  String?
  startAt      DateTime
  endAt        DateTime
  allDay       Boolean  @default(false)
  /// @pii
  location     String?
  /// @pii
  attendees    Json?
  reminder     Int      @default(30)
  visibility   String   @default("default")
  availability String   @default("BUSY")
  type         String   @default("EVENT")
  color        String   @default("#1a73e8")
  calendarId   String   @default("default")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, userId, startAt])
  @@index([tenantId, startAt, endAt])
}

model User {
  id                    String               @id @default(cuid())
  tenantId              String
  /// @pii
  email                 String
  /// @pii
  passwordHash          String
  /// @pii
  firstName             String
  /// @pii
  lastName              String
  status                UserStatus           @default(ACTIVE)
  isEmailVerified       Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deletedAt             DateTime?
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  roles                 UserRole[]
  createdStoppages      Stoppage[]           @relation("StoppageCreator")
  passwordResetTokens   PasswordResetToken[]
  invitationTokens      InvitationToken[]
  refreshSessions       RefreshSession[]
  rentalBookingsCreated RentalBooking[]      @relation("RentalBookingCreator")
  rentalPaymentMethodsCreated RentalCustomerPaymentMethod[] @relation("RentalPaymentMethodCreator")
  rentalDepositsCreated       RentalDeposit[]               @relation("RentalDepositCreator")
  rentalDepositsApproved      RentalDeposit[]               @relation("RentalDepositApprover")
  rentalExtraChargesCreated   RentalExtraCharge[]           @relation("RentalExtraChargeCreator")
  rentalExtraChargesApproved  RentalExtraCharge[]           @relation("RentalExtraChargeApprover")
  privacyAcceptances    PrivacyAcceptance[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

model RefreshSession {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  tokenHash    String    @unique
  /// @pii
  userAgent    String?
  /// @pii
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt])
  @@index([tenantId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model InvitationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  key         RoleKey          @unique
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Site {
  id               String            @id @default(cuid())
  tenantId         String
  name             String
  /// @pii
  address          String
  city             String
  /// @pii
  contactName      String?
  /// @pii
  email            String?
  /// @pii
  phone            String?
  /// @pii
  notes            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  vehicles         Vehicle[]
  stoppages        Stoppage[]
  rentalPriceLists RentalPriceList[]

  @@index([tenantId, isActive])
  @@index([tenantId, city])
}

model Workshop {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  /// @pii
  contactName String?
  /// @pii
  email       String?
  /// @pii
  phone       String?
  /// @pii
  whatsapp    String?
  /// @pii
  address     String?
  city        String?
  /// @pii
  notes       String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  stoppages   Stoppage[]

  @@index([tenantId, isActive])
}

model Vehicle {
  id                    String               @id @default(cuid())
  tenantId              String
  siteId                String
  /// @pii
  plate                 String
  brand                 String
  model                 String
  year                  Int?
  currentKm             Int?
  maintenanceIntervalKm Int?
  registrationDate      DateTime?
  lastRevisionAt        DateTime?
  revisionDueAt         DateTime?
  purchasePrice         Float?
  purchaseDate          DateTime?
  residualValue         Float?
  monthlyFixedCost      Float?
  /// @pii
  notes                 String?
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deletedAt             DateTime?
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  site                  Site                 @relation(fields: [siteId], references: [id])
  photos                VehiclePhoto[]
  booklet               VehicleBooklet?
  stoppages             Stoppage[]
  maintenances          VehicleMaintenance[]
  costs                 VehicleCost[]
  rentalBookings        RentalBooking[]
  rentalDeposits        RentalDeposit[]
  rentalExtraCharges    RentalExtraCharge[]
  rentalPriceLists      RentalPriceList[]

  @@index([tenantId, siteId])
  @@index([tenantId, revisionDueAt])
}

model VehicleCost {
  id          String          @id @default(cuid())
  tenantId    String
  vehicleId   String
  type        VehicleCostType @default(OTHER)
  description String?
  amount      Float
  date        DateTime
  recurring   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id])

  @@index([tenantId, vehicleId, date])
  @@index([tenantId, type])
  @@index([tenantId, deletedAt])
}

model VehicleMaintenance {
  id              String                         @id @default(cuid())
  tenantId        String
  vehicleId       String
  performedAt     DateTime
  maintenanceType String
  /// @pii
  description     String?
  /// @pii
  workshopName    String?
  kmAtService     Int?
  cost            Float?
  /// @pii
  notes           String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  deletedAt       DateTime?
  tenant          Tenant                         @relation(fields: [tenantId], references: [id])
  vehicle         Vehicle                        @relation(fields: [vehicleId], references: [id])
  attachments     VehicleMaintenanceAttachment[]

  @@index([tenantId, vehicleId])
  @@index([tenantId, performedAt])
}

model VehicleMaintenanceAttachment {
  id                 String             @id @default(cuid())
  tenantId           String
  maintenanceId      String
  /// @pii
  filePath           String
  /// @pii
  fileName           String
  mimeType           String
  sizeBytes          Int
  invoiceTotalAmount Float?
  createdAt          DateTime           @default(now())
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  maintenance        VehicleMaintenance @relation(fields: [maintenanceId], references: [id])

  @@index([tenantId, maintenanceId])
  @@index([maintenanceId])
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String
  /// @pii
  filePath  String
  /// @pii
  fileName  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model VehicleBooklet {
  id                        String    @id @default(cuid())
  tenantId                  String
  vehicleId                 String    @unique
  /// @pii
  filePath                  String
  /// @pii
  fileName                  String
  mimeType                  String
  sizeBytes                 Int
  extractedRegistrationDate DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  tenant                    Tenant    @relation(fields: [tenantId], references: [id])
  vehicle                   Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([tenantId, vehicleId])
}

model RentalBooking {
  id                   String                        @id @default(cuid())
  tenantId             String
  vehicleId            String
  customerId           String?
  contractRequired     Boolean                       @default(true)
  createdByUserId      String?
  code                 String
  status               RentalBookingStatus           @default(DRAFT)
  contractStatus       RentalContractStatus          @default(NOT_READY)
  cargosStatus         RentalCargosStatus            @default(NOT_REQUIRED)
  /// @pii
  customerName         String
  /// @pii
  customerEmail        String?
  /// @pii
  customerPhone        String?
  /// @pii
  customerDocument     String?
  pickupAt             DateTime
  returnAt             DateTime
  /// @pii
  pickupLocation       String?
  /// @pii
  returnLocation       String?
  pickupKm             Int?
  returnKm             Int?
  expectedTotal        Float?
  finalTotal           Float?
  /// @pii
  reason               String?
  /// @pii
  internalNotes        String?
  contractSignedAt     DateTime?
  cargosSentAt         DateTime?
  /// @pii
  cargosOutcomeMessage String?
  cargosTransmissionId String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  deletedAt            DateTime?
  tenant               Tenant                        @relation(fields: [tenantId], references: [id])
  vehicle              Vehicle                       @relation(fields: [vehicleId], references: [id])
  customer             RentalCustomer?               @relation(fields: [customerId], references: [id])
  createdBy            User?                         @relation("RentalBookingCreator", fields: [createdByUserId], references: [id])
  notes                RentalBookingNote[]
  attachments          RentalCustomerAttachment[]
  contract             BookingContract?
  pricingSnapshot      RentalBookingPricingSnapshot?
  paymentMethods       RentalCustomerPaymentMethod[]
  rentalDeposits       RentalDeposit[]
  rentalExtraCharges   RentalExtraCharge[]
  rentalPaymentEvents  RentalPaymentEvent[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, contractStatus])
  @@index([tenantId, cargosStatus])
  @@index([tenantId, pickupAt])
  @@index([tenantId, returnAt])
  @@index([tenantId, customerId])
  @@index([tenantId, customerId, pickupAt])
  @@index([vehicleId, pickupAt, returnAt])
}

model RentalBookingNote {
  id        String        @id @default(cuid())
  tenantId  String
  bookingId String
  userId    String?
  type      String        @default("NOTE")
  /// @pii
  message   String
  createdAt DateTime      @default(now())
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  booking   RentalBooking @relation(fields: [bookingId], references: [id])

  @@index([tenantId, bookingId, createdAt])
}

model RentalCustomer {
  id                      String                     @id @default(cuid())
  tenantId                String
  customerType            RentalCustomerType         @default(PERSONA_FISICA)
  /// @pii
  firstName               String
  /// @pii
  lastName                String
  /// @pii
  drivingLicenseNumber    String                     @default("")
  /// @pii
  drivingLicenseIssuedAt  DateTime?
  /// @pii
  drivingLicenseExpiresAt DateTime?
  /// @pii
  drivingLicenseAuthority String?
  /// @pii
  drivingLicenseCategory  String?
  /// @pii
  email                   String?
  /// @pii
  phone                   String?
  /// @pii
  dateOfBirth             DateTime?
  /// @pii
  placeOfBirth            String?
  birthCountry            String?
  /// @pii
  birthProvince           String?
  /// @pii
  birthMunicipalityCode   String?
  /// @pii
  birthCity               String?
  /// @pii
  nationality             String?
  nationalityCountry      String?
  /// @pii
  residenceAddress        String?
  residenceCountry        String?
  /// @pii
  residenceRegion         String?
  /// @pii
  residenceProvince       String?
  /// @pii
  residenceMunicipalityCode String?
  /// @pii
  residenceCity           String?
  /// @pii
  residencePostalCode     String?
  /// @pii
  residenceStreetAddress  String?
  /// @pii
  taxCode                 String?
  /// @pii
  documentType            String?
  /// @pii
  documentNumber          String?
  /// @pii
  documentIssuedAt        DateTime?
  /// @pii
  documentExpiresAt       DateTime?
  /// @pii
  documentAuthority       String?
  /// @pii
  companyName             String?
  /// @pii
  companyLegalForm        String?
  /// @pii
  companyVatNumber        String?
  /// @pii
  companyTaxCode          String?
  /// @pii
  companyLegalAddress     String?
  companyCountry          String?
  /// @pii
  companyRegion           String?
  /// @pii
  companyProvince         String?
  /// @pii
  companyMunicipalityCode String?
  /// @pii
  companyCity             String?
  /// @pii
  companyPostalCode       String?
  /// @pii
  companyStreetAddress    String?
  /// @pii
  companyPec              String?
  /// @pii
  companySdi              String?
  /// @pii
  companyRea              String?
  /// @pii
  legalRepFirstName       String?
  /// @pii
  legalRepLastName        String?
  /// @pii
  legalRepTaxCode         String?
  /// @pii
  legalRepRole            String?
  /// @pii
  legalRepEmail           String?
  /// @pii
  legalRepPhone           String?
  /// @pii
  notes                   String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant                     @relation(fields: [tenantId], references: [id])
  bookings                RentalBooking[]
  attachments             RentalCustomerAttachment[]
  paymentProfiles         RentalCustomerPaymentProfile[]
  paymentMethods          RentalCustomerPaymentMethod[]
  rentalDeposits          RentalDeposit[]
  rentalExtraCharges      RentalExtraCharge[]
