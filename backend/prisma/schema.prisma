  /// @pii
  subject       String
  /// @pii
  body          String
  /// @pii
  meta          Json?
  status        EmailQueueStatus @default(PENDING)
  attempts      Int              @default(0)
  maxAttempts   Int              @default(5)
  nextAttemptAt DateTime         @default(now())
  /// @pii
  lastError     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, nextAttemptAt])
}

model Invoice {
  id               String             @id @default(cuid())
  tenantId         String
  invoiceNumber    String             @unique
  issueDate        DateTime
  dueDate          DateTime
  periodStart      DateTime
  periodEnd        DateTime
  status           InvoiceStatus      @default(GENERATED)
  currency         String             @default("EUR")
  subtotal         Float
  taxRate          Float
  taxAmount        Float
  total            Float
  /// @pii
  billingName      String
  /// @pii
  billingVatNumber String?
  /// @pii
  billingTaxCode   String?
  /// @pii
  billingAddress   String?
  /// @pii
  billingEmail     String?
  /// @pii
  billingPec       String?
  /// @pii
  billingSdi       String?
  /// @pii
  notes            String?
  /// @pii
  pdfFilePath      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  sentAt           DateTime?
  deletedAt        DateTime?
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  items            InvoiceItem[]
  deliveries       InvoiceDelivery[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([status, createdAt])
  @@index([sentAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  /// @pii
  description String
  quantity    Float
  unitPrice   Float
  subtotal    Float
  taxRate     Float
  taxAmount   Float
  total       Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceDelivery {
  id                String                 @id @default(cuid())
  invoiceId         String
  channel           InvoiceDeliveryChannel @default(EMAIL)
  /// @pii
  recipient         String
  status            InvoiceDeliveryStatus  @default(PENDING)
  provider          String?
  /// @pii
  providerMessageId String?
  /// @pii
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime               @default(now())
  invoice           Invoice                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@index([status, createdAt])
}

model WebsiteEvent {
  id            String           @id @default(cuid())
  eventType     WebsiteEventType
  path          String
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  deviceType    String?
  browser       String?
  country       String?
  consentAnalytics Boolean          @default(true)
  /// @pii
  ipHash        String?
  /// @pii
  userAgentHash String?
  /// @pii
  visitorId     String?
  /// @pii
  sessionId     String?
  /// @pii
  metadata      Json?
  createdAt     DateTime         @default(now())

  @@index([eventType, createdAt])
  @@index([path, createdAt])
  @@index([visitorId, createdAt])
  @@index([sessionId, createdAt])
  @@index([createdAt])
}

model DemoLead {
  id                  String         @id @default(cuid())
  /// @pii
  companyName         String
  /// @pii
  fullName            String
  /// @pii
  email               String
  /// @pii
  phone               String?
  fleetSize           String?
  /// @pii
  message             String?
  source              String         @default("fleetum.it")
  status              DemoLeadStatus @default(NEW)
  referrer            String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  /// @pii
  visitorId           String?
  /// @pii
  sessionId           String?
  emailQueueId        String?
  emailDeliveryStatus String?
  contactedAt         DateTime?
  archivedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
}
