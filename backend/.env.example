# Fleetum Backend Environment Example
# Copy this file to backend/.env for local development.
# Never commit real secrets, passwords, tokens, API keys or production credentials.

# -----------------------------------------------------------------------------
# Runtime / App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
PLATFORM_PORT=4100
PLATFORM_BIND_HOST=127.0.0.1
TRUST_PROXY=false
SHUTDOWN_GRACE_MS=15000

# Public URLs used for CORS, redirects, OAuth callbacks and emails.
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_URL=http://127.0.0.1:4000
BACKEND_PUBLIC_URL=http://127.0.0.1:4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
PLATFORM_CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
OAUTH_CALLBACK_URL=http://localhost:5173/auth/social-callback

# -----------------------------------------------------------------------------
# Database / Prisma
# -----------------------------------------------------------------------------
# Prisma PostgreSQL URL format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/fleetum_dev?schema=public

# -----------------------------------------------------------------------------
# Tenant Auth / JWT
# -----------------------------------------------------------------------------
# Minimum 32 chars. Use a long random value in production.
JWT_SECRET=change_me_tenant_jwt_secret_min_32_chars_0000
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Platform Console Auth / OTP / IP Allowlist
# -----------------------------------------------------------------------------
PLATFORM_ADMIN_EMAIL=info@example.com
PLATFORM_ADMIN_PASSWORD=change_me_platform_admin_password_min_20_chars
# Must be different from JWT_SECRET and at least 64 chars.
PLATFORM_JWT_SECRET=change_me_platform_jwt_secret_min_64_chars_000000000000000000000000000000
PLATFORM_JWT_EXPIRES_IN=15m
# Optional static emergency OTP for local-only testing. Leave empty in production.
PLATFORM_ADMIN_OTP=
# Optional signing/encryption secret for OTP flows if enabled by the implementation.
PLATFORM_OTP_SECRET=change_me_platform_otp_secret_min_32_chars
PLATFORM_OTP_EXPIRES_MINUTES=10
# Comma-separated IPs/CIDRs allowed to access Platform Console. Empty = no allowlist.
PLATFORM_ALLOWED_IPS=127.0.0.1,::1
PLATFORM_ALERT_EMAILS=info@example.com
PLATFORM_LOGIN_MAX_ATTEMPTS=5
PLATFORM_LOGIN_WINDOW_MS=900000
PLATFORM_LOGIN_LOCK_MS=1800000

# -----------------------------------------------------------------------------
# OAuth login/signup
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://127.0.0.1:4000/api/auth/google/callback
GOOGLE_WORKSPACE_REDIRECT_URI=http://127.0.0.1:4000/api/calendar/google/callback
APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APPLE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
APPLE_REDIRECT_URI=http://127.0.0.1:4000/api/auth/apple/callback

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Supported: smtp | resend
EMAIL_PROVIDER=resend

# Resend provider. Required when EMAIL_PROVIDER=resend.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM="Fleetum <no-reply@fleetum.it>"
DEMO_LEAD_RECIPIENT_EMAIL=info@fleetum.it

# SMTP fallback. Required when EMAIL_PROVIDER=smtp.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=smtp_user@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM="Fleetum <no-reply@fleetum.it>"

# -----------------------------------------------------------------------------
# Stripe / Billing
# -----------------------------------------------------------------------------
BILLING_TRIAL_DAYS=14
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER_MONTHLY=price_YOUR_STARTER_MONTHLY_PRICE_ID
STRIPE_PRICE_STARTER_YEARLY=price_YOUR_STARTER_YEARLY_PRICE_ID
STRIPE_PRICE_PRO_MONTHLY=price_YOUR_PRO_MONTHLY_PRICE_ID
STRIPE_PRICE_PRO_YEARLY=price_YOUR_PRO_YEARLY_PRICE_ID
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_YOUR_ENTERPRISE_MONTHLY_PRICE_ID
STRIPE_PRICE_ENTERPRISE_YEARLY=price_YOUR_ENTERPRISE_YEARLY_PRICE_ID
# Optional generic fallback price ID for legacy integrations.
STRIPE_PRICE_ID=price_YOUR_DEFAULT_PRICE_ID

# -----------------------------------------------------------------------------
# Storage / Uploads
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_BYTES=10485760
# Supported: local | s3
STORAGE_PROVIDER=local
# Required only when STORAGE_PROVIDER=s3.
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=fleetum-documents
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
S3_REGION=auto
S3_PUBLIC_BASE_URL=https://cdn.example.com/fleetum-documents

# -----------------------------------------------------------------------------
# Cron / Compliance / SLA
# -----------------------------------------------------------------------------
PRIVACY_RETENTION_CRON_ENABLED=false
PRIVACY_RETENTION_CRON_SCHEDULE=30 3 * * *
CRON_REMINDER_SCHEDULE=*/10 * * * *
SLA_PRIORITY_THRESHOLDS={"LOW":15,"MEDIUM":10,"HIGH":5,"CRITICAL":2}

# -----------------------------------------------------------------------------
# Fleetum invoice identity placeholders
# -----------------------------------------------------------------------------
FLEETUM_BILLING_LEGAL_NAME=Fleetum
FLEETUM_BILLING_VAT=YOUR_VAT_NUMBER
FLEETUM_BILLING_ADDRESS=YOUR_LEGAL_ADDRESS
FLEETUM_BILLING_EMAIL=info@fleetum.it
FLEETUM_BILLING_PEC=YOUR_PEC@example.com
FLEETUM_BILLING_SDI=YOUR_SDI_CODE
FLEETUM_BILLING_IBAN=IT00X0000000000000000000000

# -----------------------------------------------------------------------------
# Local demo seed only
# -----------------------------------------------------------------------------
DEMO_ADMIN_PASSWORD=replace_me_demo_password_min_12_chars
DEMO_TENANT_ADMIN_EMAIL=admin@fleetum.it
DEMO_TENANT_ID=
ALLOW_DEMO_SEED_PRODUCTION=false
