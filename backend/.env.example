NODE_ENV=development
PORT=4000
SHUTDOWN_GRACE_MS=15000
DATABASE_URL=postgresql://fleetum:fleetum_dev@localhost:5433/fleetum?schema=public
JWT_SECRET=change_me_super_secret_at_least_32_chars
# Il refresh token (30gg) rinnova automaticamente l'access token.
JWT_EXPIRES_IN=15m
UPLOAD_DIR=uploads
FILE_MAX_IMAGE_MB=5
FILE_MAX_DOCUMENT_MB=12
FILE_MAX_LOGO_MB=4
IMAGE_MAX_WIDTH_PX=1920
IMAGE_COMPRESSION_QUALITY=82
IMAGE_PNG_COMPRESSION_LEVEL=9
STORAGE_PROVIDER=local
# S3-compatible private object storage. Supported providers:
# - AWS S3: S3_ENDPOINT=https://s3.eu-south-1.amazonaws.com, S3_REGION=eu-south-1
# - Cloudflare R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, S3_REGION=auto
# - Backblaze B2: S3_ENDPOINT=https://s3.<region>.backblazeb2.com, S3_REGION=<region>
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_EXPIRES_SECONDS=300
# Observability
# Default: 100ms in development, 500ms in production. Non logga parametri SQL.
PRISMA_SLOW_QUERY_MS=
METRICS_ENABLED=true
# In produzione configurare un token e leggere /api/metrics con Authorization: Bearer <token>.
METRICS_TOKEN=
PRIVACY_RETENTION_CRON_ENABLED=false
PRIVACY_RETENTION_CRON_SCHEDULE="30 3 * * *"
APP_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://127.0.0.1:4000
CORS_ORIGIN=http://localhost:5173
PLATFORM_PORT=4100
PLATFORM_CORS_ORIGIN=http://localhost:5174
OAUTH_CALLBACK_URL=http://localhost:5173/auth/social-callback

# Google OAuth login/signup.
# Non committare mai client secret reali: in produzione inserirli solo nei GitHub Actions/VPS secrets.
# Redirect autorizzato in Google Cloud Console local:
# http://127.0.0.1:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:4000/api/auth/google/callback
GOOGLE_WORKSPACE_REDIRECT_URI=http://127.0.0.1:4000/api/calendar/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://127.0.0.1:4000/api/auth/apple/callback
# Email delivery uses Resend. RESEND_FROM must use a sender/domain verified in Resend.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM="Fleetum <no-reply@fleetum.it>"
DEMO_LEAD_RECIPIENT_EMAIL=info@fleetum.it
CRON_REMINDER_SCHEDULE=*/10 * * * *
SLA_PRIORITY_THRESHOLDS={"LOW":15,"MEDIUM":10,"HIGH":5,"CRITICAL":2}
PLATFORM_ADMIN_EMAIL=info@fleetum.it
# Genera un hash completo: node -e "require('bcryptjs').hash('TUA_PASSWORD',12).then(console.log)"
# In produzione Docker Compose legge backend.env con format: raw, quindi non aggiungere virgolette.
PLATFORM_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_A_REAL_60_CHARACTER_BCRYPT_HASH
PLATFORM_JWT_SECRET=replace_with_platform_jwt_secret_min_64_chars
PLATFORM_JWT_EXPIRES_IN=15m
# strict = solo IP allowlist; optional = IP allowlist oppure dispositivo fidato dopo OTP; disabled = solo password+OTP+JWT.
PLATFORM_IP_ALLOWLIST_MODE=optional
PLATFORM_TRUSTED_DEVICE_ENABLED=true
PLATFORM_TRUSTED_DEVICE_TTL_DAYS=90
PLATFORM_ALLOWED_IPS=127.0.0.1,::1,203.0.113.10
PLATFORM_ALERT_EMAILS=info@fleetum.it
PLATFORM_BIND_HOST=127.0.0.1
# In produzione con Caddy impostare a 1 (un livello di proxy).
# In locale senza proxy lasciare false.
TRUST_PROXY=false
PLATFORM_LOGIN_MAX_ATTEMPTS=5
PLATFORM_LOGIN_WINDOW_MS=900000
PLATFORM_LOGIN_LOCK_MS=1800000
DEMO_ADMIN_PASSWORD=replace_me_demo_password_min_12_chars

# Billing SaaS / Stripe
# I nuovi tenant nascono PENDING: il gestionale si abilita solo dopo webhook Stripe
# con subscription ACTIVE o TRIAL. In local puoi lasciare STRIPE_SECRET_KEY vuoto
# e usare il checkout mock locale; in produzione Stripe deve essere configurato.
# Il trial Stripe raccoglie comunque una carta valida prima di abilitare il gestionale.
BILLING_TRIAL_DAYS=14
# Giorni usati per comunicazioni e dunning PAST_DUE. Non sblocca il license guard.
BILLING_PAST_DUE_GRACE_DAYS=7
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
# Customer Portal Stripe: abilita fatture, piani e cancellazione lato Stripe.
# Lascia vuota CONFIGURATION_ID per usare la configurazione predefinita del dashboard Stripe.
STRIPE_PORTAL_RETURN_URL=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
