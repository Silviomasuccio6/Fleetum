# Fleetum local development defaults
# Copy this file to .env.local if you want Docker Compose to load local values.

POSTGRES_CONTAINER_NAME=fleetum_postgres_local
POSTGRES_USER=fleetum
POSTGRES_PASSWORD=fleetum_local_password
POSTGRES_DB=fleetum
POSTGRES_PORT=5433

# Prisma local DATABASE_URL example:
# DATABASE_URL=postgresql://fleetum:fleetum_local_password@localhost:5433/fleetum?schema=public
